rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { 
      allow read, write: if false; 
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { 
      return request.resource.data; 
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['fullName', 'businessName', 'email', 'phone', 'projectDetails', 'createdAt']) &&
        data.keys().size() == 6 &&
        data.fullName is string && data.fullName.size() > 0 && data.fullName.size() <= 200 &&
        data.businessName is string && data.businessName.size() <= 200 &&
        data.email is string && data.email.size() > 0 && data.email.size() <= 200 &&
        data.phone is string && data.phone.size() <= 50 &&
        data.projectDetails is string && data.projectDetails.size() > 0 && data.projectDetails.size() <= 5000 &&
        data.createdAt == request.time;
    }

    match /messages/{messageId} {
      allow create: if isValidId(messageId) && isValidMessage(incoming());
      allow read, update, delete: if false;
    }
  }
}
